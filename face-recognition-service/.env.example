# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/face_recognition

# Face Recognition thresholds
FACE_RECOGNITION_THRESHOLD=0.35
FACE_DETECTION_THRESHOLD=0.5
LIVENESS_THRESHOLD=0.7

# Face processing
MIN_FACE_SIZE=80
MAX_EMBEDDING_DIM=512
EMBEDDING_AVG_METHOD=mean

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080

# Door control
DOOR_ENABLED=false